# graphify scope for canvas-agent.
# Graph covers: src/ + scripts/ + docs/ + top-level *.md docs.
# Everything below is excluded from the knowledge graph.

# Dependencies / build artifacts
node_modules/
dist/
build/
release/
*.tsbuildinfo

# Local Python sidecar virtualenv (Docling) — graphify's default skip-set
