.venv-docling/

# Staged release payloads (bundled Chromium / Ollama / docling binaries — gitignored,
# machine-staged blobs with thousands of internal files; never graph them).
resources/ms-playwright/
resources/sidecars/

# graphify's own output (avoid graphing the graph)
graphify-out/

# Agent tooling dirs
.claude/
.codex/

# Logs, OS cruft, secrets, local data
*.log
.DS_Store
.env
.env.local
data/

# Lockfiles
package-lock.json

# Out of graph scope (kept narrow per request: docs + scripts, not tests/config).
# Remove these lines to fold them into the graph.
e2e/
package.json
tsconfig.json
