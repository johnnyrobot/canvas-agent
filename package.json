{
  "name": "canvas-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Canvas Course Design & Accessibility Assistant — on-device, single-user macOS app (see PRD).",
  "main": "dist/app/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "tsx --test 'src/**/*.test.ts' 'e2e/**/*.test.ts'",
    "e2e": "tsx --test 'e2e/**/*.test.ts'",
    "app": "tsc && cp src/app/renderer/index.html dist/app/renderer/index.html && electron .",
    "llm:smoke": "tsx src/llm/example.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "axe-core": "^4.12.0",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "ai.johnnyrobot.canvasagent",
    "productName": "Canvas Agent",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "!**/*.test.{js,d.ts}"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "resources/sidecars/ollama",
        "to": "sidecars/ollama",
        "filter": ["**/*"]
      },
      {
        "from": "resources/sidecars/docling-serve",
        "to": "sidecars/docling-serve",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Canvas Agent ${version}"
    }
  }
}
