{
  "name": "canvas-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Canvas Course Design & Accessibility Assistant — on-device, single-user macOS app (see PRD).",
  "main": "dist/app/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc && npm run copy:assets",
    "copy:assets": "mkdir -p dist/knowledge/packs dist/app/renderer && cp src/knowledge/packs/*.json dist/knowledge/packs/ && cp src/app/renderer/index.html dist/app/renderer/index.html",
    "test": "tsx --test 'src/**/*.test.ts' 'e2e/**/*.test.ts'",
    "e2e": "tsx --test 'e2e/**/*.test.ts'",
    "app": "npm run build && electron .",
    "llm:smoke": "tsx src/llm/example.ts",
    "verify": "tsc --noEmit && npm test",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "install:hooks": "git config core.hooksPath githooks",
    "prepare": "git config core.hooksPath githooks || true",
    "stage:browsers": "PLAYWRIGHT_BROWSERS_PATH=\"$PWD/resources/ms-playwright\" npx playwright install chromium",
    "stage:sidecars": "node scripts/stage-resources.mjs",
    "pre-release": "node scripts/pre-release.mjs",
    "package": "npm run build && node scripts/pre-release.mjs --strict && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "axe-core": "^4.12.0",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "ai.johnnyrobot.canvasagent",
    "productName": "Canvas Agent",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "!**/*.test.{js,d.ts}"
    ],
    "asar": true,
    "afterPack": "build-resources/afterPack.js",
    "extraResources": [
      {
        "from": "resources/ms-playwright",
        "to": "ms-playwright",
        "filter": ["**/*"]
      },
      {
        "from": "resources/sidecars/ollama",
        "to": "sidecars/ollama",
        "filter": ["**/*"]
      },
      {
        "from": "resources/sidecars/docling-serve",
        "to": "sidecars/docling-serve",
        "filter": ["**/*"]
      },
      {
        "from": "THIRD-PARTY-NOTICES.md",
        "to": "THIRD-PARTY-NOTICES.md"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "signIgnore": ["/Contents/Resources/sidecars/"],
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Canvas Agent ${version}"
    }
  }
}
